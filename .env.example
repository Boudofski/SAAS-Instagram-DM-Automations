# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/replyflow

# ─────────────────────────────────────────────
# Clerk Authentication
# https://dashboard.clerk.com → your app → API Keys
# ─────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/dashboard

# ─────────────────────────────────────────────
# App URL
# ─────────────────────────────────────────────
NEXT_PUBLIC_HOST_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Stripe Billing
# https://dashboard.stripe.com → Developers → API keys
# STRIPE_CLIENT_SECRET      = secret key (sk_test_... or sk_live_...)
# STRIPE_WEBHOOK_SECRET     = from `stripe listen` CLI or Dashboard webhook endpoint
# STRIPE_SUBSCRIPTION_PRICE_ID = price ID for Creator plan (price_...)
# ─────────────────────────────────────────────
STRIPE_CLIENT_SECRET=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUBSCRIPTION_PRICE_ID=price_...

# ─────────────────────────────────────────────
# Meta / Instagram Graph API
# https://developers.facebook.com → your app
#
# META_VERIFY_TOKEN          = any secret string you choose; must match
#                              the value entered in Meta webhook config
# META_REDIRECT_URI          = must match exactly in Meta app OAuth settings
# INSTAGRAM_EMBEDDED_OAUTH_URL = full OAuth URL from your Meta app's
#                              Instagram Basic Display settings
# INSTAGRAM_TOKEN_URL        = https://api.instagram.com/oauth/access_token
# ─────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=a-random-secret-you-choose
META_REDIRECT_URI=http://localhost:3000/callback/instagram
INSTAGRAM_BASE_URL=https://graph.instagram.com
INSTAGRAM_EMBEDDED_OAUTH_URL=https://api.instagram.com/oauth/authorize?client_id=YOUR_CLIENT_ID&redirect_uri=http://localhost:3000/callback/instagram&scope=user_profile,user_media,instagram_manage_messages,instagram_manage_comments&response_type=code
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_TOKEN_URL=https://api.instagram.com/oauth/access_token

# ─────────────────────────────────────────────
# OpenAI (for Smart AI listener mode)
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379   # reserved for future async queue
